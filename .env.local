# DeepSeek API Key - 从 DeepSeek 平台获取: https://platform.deepseek.com
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# FastAPI 服务地址（用于剧本解析）
NEXT_PUBLIC_API_URL=http://localhost:8000

# 数据库连接（Docker compose 时使用）
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/scriptstore

# 会话密钥 - 请替换为随机字符串
SESSION_SECRET=change_this_to_a_random_secret_key
